# ─── Адрес сайта (главная настройка) ─────────────────────────
# Ваш IP или домен. Пример без домена: http://123.45.67.89
# С портом (если без nginx): http://123.45.67.89:3000
NEXT_PUBLIC_SITE_URL=http://123.45.67.89

# ─── Node.js ─────────────────────────────────────────────────
PORT=3000
# 0.0.0.0 — доступ по IP напрямую (без nginx)
# 127.0.0.1 — только через nginx на порту 80
HOSTNAME=0.0.0.0

# ─── Путь на сервере ─────────────────────────────────────────
DEPLOY_PATH=/var/www/esperanza

# ─── Домен для nginx (когда появится) ────────────────────────
SERVER_NAME=example.com www.example.com
