# ─── Адрес сайта ─────────────────────────────────────────────
# Публичный URL (с https). Пример: https://esperanza.ru
NEXT_PUBLIC_SITE_URL=https://example.com

# ─── Node.js на сервере ──────────────────────────────────────
# Порт, на котором слушает Next.js (nginx проксирует сюда)
PORT=3000
HOSTNAME=127.0.0.1

# ─── Путь на сервере ─────────────────────────────────────────
# Папка, куда копируется готовый сайт (release/)
# Пример Linux: /var/www/esperanza
# Пример Windows IIS/Node: C:\inetpub\esperanza
DEPLOY_PATH=/var/www/esperanza

# ─── Домен для nginx (опционально) ───────────────────────────
SERVER_NAME=example.com www.example.com
